---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { services, serviceNames } from "../lib/services.js";
import { icons } from "../lib/brand.js";
import { site } from "../site.js";

export async function getStaticPaths() {
  return services.map(s => ({ params: { service: s.slug }, props: { svc: s } }));
}
const { svc } = Astro.props;
const url = site.url + "/" + svc.slug + "/";
const built = new Set(services.map(s => s.slug));
const related = (svc.related || []).map(slug => ({ slug, name: serviceNames[slug] })).filter(r => r.name && built.has(r.slug));

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url + "/" },
      { "@type": "ListItem", position: 2, name: "Security Services", item: site.url + "/security-services-melbourne/" },
      { "@type": "ListItem", position: 3, name: svc.breadcrumb, item: url },
    ]},
    { "@type": "Service", name: svc.h1, serviceType: svc.primaryKW, areaServed: "Melbourne, Victoria, Australia",
      provider: { "@type": ["Organization","SecurityService","LocalBusiness"], name: site.brand, url: site.url, telephone: site.phone },
      description: svc.metaDesc, url: url },
    { "@type": "FAQPage", mainEntity: svc.faqs.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
  ],
};
const midText = svc.midcta || { b: "Need cover fast?", span: "Licensed guards on call 24/7 across Melbourne." };
const accreditations = [
  { icon: "shieldcheck", name: "Victoria Police", sub: "Licensed business" },
  { icon: "guard", name: "ASIAL Member", sub: "Industry accredited" },
  { icon: "grid", name: "ISO 9001", sub: "Quality certified" },
  { icon: "clock", name: "24/7 Monitored", sub: "Control room" },
  { icon: "pin", name: "Melbourne based", sub: "Australian owned" },
];
---
<Base title={svc.title} description={svc.metaDesc} path={"/" + svc.slug + "/"} ogImage={svc.og}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header />

  <!-- HERO -->
  <section class="hero">
    <div class="wm wm-hero" aria-hidden="true"></div>
    <div class="container svc-hero-grid" style="padding:60px 24px 70px">
      <div>
        <div class="crumbs" style="color:#B9B7A6"><a href="/" style="color:var(--lime-soft)">Home</a> &nbsp;/&nbsp; <a href="/security-services-melbourne/" style="color:var(--lime-soft)">Services</a> &nbsp;/&nbsp; {svc.breadcrumb}</div>
        <h1 style="margin-top:10px">{svc.h1}</h1>
        <p class="lead">{svc.intro}</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap">
          <a class="btn btn-primary" href="/contact/">Get a Free Quote</a>
          <a class="btn btn-ghost" style="border-color:var(--lime);color:var(--cream)" href={site.phoneHref}>Call {site.phone}</a>
        </div>
        <div class="prefoot-trust" style="margin-top:20px"><span>Victorian licensed</span><span>Fully insured</span><span>Police-checked</span><span>24/7</span></div>
      </div>
      <div style="position:relative"><img class="shot" src={svc.heroImg} alt={svc.heroAlt} width="540" height="405" fetchpriority="high" /><div class="svc-badge"><span class="ldot"></span>Licensed &amp; insured</div></div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section bg-soft" style="padding:46px 0">
    <div class="container"><div class="stats">{site.stats.map(s => (<div class="stat reveal"><b>{s.n}</b><span>{s.label}</span></div>))}</div></div>
  </section>

  <!-- ACCREDITATIONS -->
  <section class="section bg-cream" style="padding:46px 0">
    <div class="container">
      <p class="acc-head">Trusted, licensed and accredited to protect Melbourne</p>
      <div class="acc-grid">{accreditations.map(a => (<div class="acc-badge reveal"><span class="ab-mark" set:html={icons[a.icon]} /><span><b>{a.name}</b><span>{a.sub}</span></span></div>))}</div>
    </div>
  </section>

  {svc.sections.map(sec => (
    sec.type === "steps" ? (
      <section class="section bg-olive" style="margin:0 24px">
        <div class="container">
          <div class="center-head reveal"><span class="eyebrow" style="color:var(--lime-soft)">How it works</span><h2 style="color:var(--cream)">{sec.h2}</h2>{sec.lead && <p class="svc-lead center" style="color:#CFCDBC">{sec.lead}</p>}</div>
          <div class="stepgrid">
            {sec.items.map(s => (<div class="step reveal"><div class="ic" set:html={icons[s.icon]} /><div class="n">{s.n}</div><h3>{s.t}</h3><p>{s.d}</p></div>))}
          </div>
        </div>
      </section>
    ) : (
      <section class={"svc-sec section " + (sec.bg || "bg-white")}>
        <div class="container">
          <div class="center-head reveal">
            <h2>{sec.h2}</h2>
            {sec.leadHtml ? <p class="svc-lead center" set:html={sec.leadHtml} /> : (sec.lead && <p class="svc-lead center">{sec.lead}</p>)}
          </div>
          {sec.type === "cards" && (
            <div class="cards">{sec.items.map(c => (<div class="card reveal"><div class="ic" set:html={icons[c.icon]} /><h3 style="font-size:1.05rem">{c.name}</h3><p style="margin-bottom:0">{c.note}</p></div>))}</div>
          )}
          {sec.type === "iconlist" && (
            <div class="iconlist">{sec.items.map(it => (<div class="it reveal"><span class="ic" set:html={icons[it.icon]} /><div><b>{it.b}</b><p>{it.p}</p></div></div>))}</div>
          )}
          {sec.type === "pills" && (
            <div class="pillgrid">{sec.items.map(p => (<span class="pill reveal"><span set:html={icons[p.icon]} />{p.label}</span>))}</div>
          )}
          {sec.type === "areas" && (
            <div>
              <div class="pillgrid">{sec.items.map(a => (<span class="pill"><span set:html={icons.pin} />{a}</span>))}</div>
              {sec.link && <p style="text-align:center;margin-top:22px"><a class="btn btn-dark" href={sec.link.href}>{sec.link.label} &rarr;</a></p>}
            </div>
          )}
          {sec.type === "table" && (
            <div>
              <div class="cost-card reveal"><table><thead><tr>{sec.head.map(h => <th>{h}</th>)}</tr></thead><tbody>{sec.rows.map(r => <tr>{r.map(cell => <td>{cell}</td>)}</tr>)}</tbody></table></div>
              {sec.note && <p class="cost-note">{sec.note}</p>}
            </div>
          )}
          {sec.bool && (
            <div class="aeo-summary" style="max-width:820px;margin:28px auto 0"><h2 style="font-size:1.05rem">{sec.bool.q}</h2><p set:html={sec.bool.a}></p></div>
          )}
        </div>
      </section>
    )
  )).flatMap((node, i) => {
    const sec = svc.sections[i];
    return sec && sec.cta ? [node, (
      <section class="bg-white" style="padding:0 0 28px"><div class="container"><div class="midcta">
        <div><b>{midText.b}</b><span>{midText.span}</span></div>
        <div class="btns"><a class="btn btn-primary" href="/contact/">Get a free quote</a><a class="btn btn-light" href={site.phoneHref}>Call {site.phone}</a></div>
      </div></div></section>
    )] : [node];
  })}

  {svc.quote && (
    <section class="section bg-white">
      <div class="container">
        <figure class="svc-quote reveal">
          <div class="stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>"{svc.quote.text}"</blockquote>
          <figcaption><span class="avatar" aria-hidden="true">{svc.quote.initials}</span><span><b>{svc.quote.name}</b><span class="role">{svc.quote.role}</span></span></figcaption>
        </figure>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section bg-soft">
    <div class="container">
      <div class="center-head reveal"><span class="eyebrow">Good to know</span><h2>{svc.breadcrumb} Melbourne <em>FAQ</em></h2></div>
      <div class="faq">{svc.faqs.map(f => (<details><summary>{f.q}</summary><p set:html={f.a}></p></details>))}</div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section bg-white">
      <div class="container">
        <div class="center-head reveal"><span class="eyebrow">Related services</span><h2>Other ways we <em>protect Melbourne</em></h2></div>
        <div class="cards" style="grid-template-columns:repeat(3,1fr)">
          {related.map(r => (<a class="card reveal" href={"/" + r.slug + "/"}><div class="ic" set:html={icons.shieldcheck} /><h3 style="font-size:1.1rem">{r.name}</h3><span class="link">Learn more &rarr;</span></a>))}
        </div>
      </div>
    </section>
  )}

  <!-- FINAL CTA -->
  <section class="section" style="padding-top:0">
    <div class="cta-band">
      <span class="eyebrow">Ready when you are</span>
      <h2>Get {svc.breadcrumb.toLowerCase()} in Melbourne <em>today</em></h2>
      <p style="color:var(--muted);max-width:48ch;margin:8px auto 24px">Licensed, insured, police-checked, and on call 24/7. Get a fast, free quote now.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a class="btn btn-dark" href="/contact/">Book a free quote</a>
        <a class="btn btn-ghost" href={site.phoneHref}>Call {site.phone}</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
