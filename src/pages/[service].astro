---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { services, serviceNames } from "../lib/services.js";
import { site } from "../site.js";

export async function getStaticPaths() {
  return services.map(s => ({ params: { service: s.slug }, props: { svc: s } }));
}
const { svc } = Astro.props;
const url = site.url + "/" + svc.slug + "/";
const related = (svc.related || []).map(slug => ({ slug, name: serviceNames[slug] || slug })).filter(r => r.name);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url + "/" },
      { "@type": "ListItem", position: 2, name: "Services", item: site.url + "/security-services-melbourne/" },
      { "@type": "ListItem", position: 3, name: svc.breadcrumb, item: url },
    ]},
    { "@type": "Service", name: svc.h1, serviceType: svc.primaryKW, areaServed: "Melbourne, Victoria, Australia",
      provider: { "@type": ["Organization", "SecurityService", "LocalBusiness"], name: site.brand, url: site.url, telephone: site.phone },
      description: svc.metaDesc, url: url },
    { "@type": "FAQPage", mainEntity: svc.faqs.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
  ],
};
---
<Base title={svc.title} description={svc.metaDesc} path={"/" + svc.slug + "/"} ogImage={svc.og}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header />

  <!-- HERO -->
  <section class="page-hero">
    <div class="container" style="display:grid;grid-template-columns:1.05fr .95fr;gap:40px;align-items:center">
      <div>
        <div class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; <a href="/security-services-melbourne/">Services</a> &nbsp;/&nbsp; {svc.breadcrumb}</div>
        <h1 style="margin-top:8px">{svc.h1}</h1>
        <p>{svc.intro}</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:22px">
          <a class="btn btn-primary" href="/contact/">Get a Free Quote</a>
          <a class="btn btn-ghost" style="border-color:var(--lime);color:var(--cream)" href={site.phoneHref}>Call {site.phone}</a>
        </div>
        <div class="prefoot-trust" style="margin-top:18px"><span>Victorian licensed</span><span>Fully insured</span><span>Police-checked</span><span>24/7</span></div>
      </div>
      <div class="hero-media" style="display:none">
        <img src={svc.heroImg} alt={svc.heroAlt} width="520" height="390" />
      </div>
    </div>
  </section>

  <section class="section bg-white" style="padding-top:44px">
    <div class="container blog-layout">
      <!-- MAIN -->
      <div class="blog-main">
        <img class="post-img" src={svc.heroImg} alt={svc.heroAlt} width="760" height="500" />
        <div class="prose" set:html={svc.bodyHtml} />

        <!-- FAQ -->
        <h2 style="font-family:var(--serif);font-size:1.7rem;margin:36px 0 14px">Security guards Melbourne FAQ</h2>
        <div class="faq">
          {svc.faqs.map(f => (<details><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
        </div>

        <!-- CTA -->
        <div class="cta-band" style="margin:36px 0 0">
          <h2>Need <em>security guards</em> in Melbourne?</h2>
          <p style="color:var(--muted);max-width:46ch;margin:8px auto 22px">Get a fast, free quote from a licensed local team. We answer the phone 24/7.</p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a class="btn btn-dark" href="/contact/">Book a free quote</a>
            <a class="btn btn-ghost" href={site.phoneHref}>Call {site.phone}</a>
          </div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="blog-side">
        <div class="side-card side-cta">
          <h4>Get a free quote</h4>
          <p>Licensed guards on call across Melbourne, 24/7. Fast, no obligation.</p>
          <a class="btn btn-primary" href="/contact/">Get a free quote</a>
          <a class="btn btn-ghost" style="border-color:var(--lime);color:var(--cream);margin-top:8px" href={site.phoneHref}>Call {site.phone}</a>
        </div>
        {related.length > 0 && (
          <div class="side-card">
            <h4>Related services</h4>
            <ul class="side-links">
              {related.map(r => <li><a href={"/" + r.slug + "/"}>{r.name} &rarr;</a></li>)}
              <li><a href="/security-services-melbourne/">All services &rarr;</a></li>
            </ul>
          </div>
        )}
        <div class="side-card">
          <h4>Service areas</h4>
          <ul class="side-links">
            <li><a href="/service-areas/">Greater Melbourne &rarr;</a></li>
            <li><a href="/security-company-geelong/">Geelong &rarr;</a></li>
            <li><a href="/security-services-melbourne-cbd/">Melbourne CBD &rarr;</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <Footer />
</Base>
