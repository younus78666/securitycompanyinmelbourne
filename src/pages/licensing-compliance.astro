---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.js";
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url + "/" },
      { "@type": "ListItem", position: 2, name: "Licensing & Compliance", item: site.url + "/licensing-compliance/" },
    ]},
    { "@type": ["Organization","SecurityService","LocalBusiness"], name: site.brand, url: site.url, telephone: site.phone,
      areaServed: "Melbourne, Victoria, Australia" },
  ],
};
---
<Base title="Licensing & Compliance | Security Company Melbourne" description="SCM holds a Victorian Private Security Business Licence, public liability insurance and police-checked guards. See our credentials and how to verify them." path="/licensing-compliance/" ogImage="/assets/og/security-guards-melbourne.jpg">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header />
  <section class="page-hero">
    <div class="container">
      <div class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; Licensing &amp; Compliance</div>
      <span class="eyebrow" style="color:var(--lime-soft)">Trust, verified</span>
      <h1 style="margin-top:8px">Licensing and compliance</h1>
      <p>Anyone can call themselves a security company. Here's the paperwork that proves we're the real thing, and how you can check it yourself before you hire us or anyone else.</p>
    </div>
  </section>
  <section class="section bg-white">
    <div class="container" style="max-width:840px">
      <div class="prose">
        <h2 id="firm-licence">Our Victorian Private Security Business Licence</h2>
        <p>We hold a current Private Security Business Licence issued by Victoria Police. That licence is what legally allows a company to supply security services in Victoria. Our licence number is shown on our quotes and invoices and is available on request, and you can verify it through the Victoria Police Licensing and Regulation Division at any time.</p>
        <h2 id="guard-licences">Every guard is individually licensed</h2>
        <p>Beyond the business licence, every officer we send holds their own current Victorian security licence for the work they do, whether that's a security officer licence, a crowd controller licence, or both. We check licences before every deployment, so an unlicensed person never works your site.</p>
        <h2 id="insurance">Insurance and police checks</h2>
        <p>We carry comprehensive public liability insurance, and every guard passes a national police check before their first shift. That protects your business, your visitors and your assets if anything ever goes wrong on site.</p>
        <h2 id="verify">How to verify a security licence in Victoria</h2>
        <p>Ask any provider for two things: their Private Security Business Licence number and confirmation that each guard is individually licensed. Then check the number with Victoria Police. A legitimate company hands these over without hesitation. If someone won't, that tells you what you need to know.</p>
        <h2 id="changes-2026">Victoria's 2026 licensing changes</h2>
        <p>Victoria tightened its private security framework in 2026, moving operators onto full licences and phasing out older registrations. We're fully compliant with the current rules. For the latest detail, check the Victoria Police private security pages directly, since requirements can change.</p>
      </div>
      <div class="cta-band" style="margin-top:36px">
        <h2>Hire a <em>properly licensed</em> Melbourne team</h2>
        <p style="color:var(--muted);max-width:46ch;margin:8px auto 22px">Licensed, insured, police-checked guards on call 24/7. Get a free quote today.</p>
        <a class="btn btn-dark" href="/contact/">Get a free quote</a>
      </div>
    </div>
  </section>
  <Footer />
</Base>
