---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.js";
const steps = [
  { n: "1", t: "Assess", d: "We review your site and risks, on the phone or on site, fast. No charge, no obligation." },
  { n: "2", t: "Quote", d: "You get a clear written quote with the right number of guards, the hours, and the price. No hidden loadings." },
  { n: "3", t: "Deploy", d: "Once you approve, we roster and deploy licensed guards fast, in uniform, briefed on your site." },
  { n: "4", t: "Report", d: "You get verified reports after every shift, plus reviews as your premises, hours or risks change." },
];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url + "/" },
      { "@type": "ListItem", position: 2, name: "Our Process", item: site.url + "/our-process/" },
    ]},
  ],
};
---
<Base title="Our Process | How SCM Security Works in Melbourne" description="How we work: assess your site, send a clear quote, deploy licensed guards fast, then report. A simple four-step security process for Melbourne businesses." path="/our-process/" ogImage="/assets/og/security-guards-melbourne.jpg">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header />
  <section class="page-hero">
    <div class="container">
      <div class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; Our Process</div>
      <span class="eyebrow" style="color:var(--lime-soft)">How it works</span>
      <h1 style="margin-top:8px">Protection in four simple steps</h1>
      <p>Hiring security shouldn't be hard work. Here's exactly how we go from your first call to guards on site, usually within hours.</p>
    </div>
  </section>
  <section class="section bg-white">
    <div class="container">
      <div class="diff" style="grid-template-columns:repeat(4,1fr)">
        {steps.map(s => (
          <div class="col"><b style="font-family:var(--serif);font-size:1.8rem;color:var(--olive)">{s.n}</b><h3 style="margin:8px 0">{s.t}</h3><p>{s.d}</p></div>
        ))}
      </div>
      <p style="text-align:center;color:var(--muted);margin-top:26px">For urgent jobs, we confirm a deployment window the moment you call. We run a 24/7 dispatch team across Melbourne, so help is never far away.</p>
      <div class="cta-band" style="margin-top:30px">
        <h2>Ready to <em>get started?</em></h2>
        <p style="color:var(--muted);max-width:46ch;margin:8px auto 22px">Step one is a quick, free chat about your site. No obligation.</p>
        <a class="btn btn-dark" href="/contact/">Get a free quote</a>
      </div>
    </div>
  </section>
  <Footer />
</Base>
