---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.js";
import { animMark, icons } from "../lib/brand.js";
import { posts } from "../lib/posts.js";

const features = [
  { title: "Protect your property, not just patrol it", body: "Stop relying on luck and locked doors. Our licensed guards deter theft, vandalism and trespass before they happen, then prove it with clear reporting.",
    proof: ["Visible deterrence that stops incidents on sight", "Written incident reports after every shift", "Uniformed, professional guards who represent you well"],
    img: "/assets/retail-guard.jpg", alt: "Licensed SCM security guard protecting a Melbourne retail site",
    link: { label: "Explore security guards", href: "/security-guards-melbourne/" }, rev: false },
  { title: "Licensed, vetted guards, every single shift", body: "You get professional people who represent your business well, not a faceless agency. Every officer is screened, licensed and accountable.",
    proof: ["Current Victorian security licence for every officer", "National police check before the first shift", "Fully insured with public liability cover"],
    img: "/assets/feature-guard.webp", alt: "Confident licensed security officer in uniform",
    link: { label: "See how we're licensed & insured", href: "/licensing-compliance/" }, rev: true },
  { title: "24/7 monitoring and rapid local response", body: "Our control room never sleeps. With GPS-verified patrols and alarm response across Greater Melbourne, we get a guard on site fast and confirm a window the moment you call.",
    proof: ["GPS-verified patrol logs you can audit", "Alarm response, lock-up and unlock cover", "A confirmed deployment window, not a vague promise"],
    img: "/assets/control-room.jpg", alt: "SCM 24/7 security control room monitoring Melbourne sites",
    link: { label: "Discover mobile patrols", href: "/mobile-patrol-security-melbourne/" }, rev: false },
];

const steps = [
  { n: "1", t: "Assess", d: "We review your site and risks, on the phone or on site, fast." },
  { n: "2", t: "Quote", d: "You get a clear written quote with the right number of guards." },
  { n: "3", t: "Deploy", d: "Once approved, licensed guards are on site fast, in uniform." },
  { n: "4", t: "Report", d: "You get verified reports, so you always know what's happening." },
];

const accreditations = [
  { icon: "shieldcheck", name: "Victoria Police", sub: "Licensed business" },
  { icon: "guard", name: "ASIAL Member", sub: "Industry accredited" },
  { icon: "grid", name: "ISO 9001", sub: "Quality certified" },
  { icon: "clock", name: "24/7 Monitored", sub: "Control room" },
  { icon: "pin", name: "Melbourne based", sub: "Australian owned" },
];

const industries = ["Retail", "Construction sites", "Events & venues", "Healthcare", "Warehouses & logistics", "Corporate offices", "Hospitality", "Body corporate & strata", "Schools", "Shopping centres"];

const testimonials = [
  { quote: "SCM's guards turned up on time, looked the part, and our incidents dropped to zero. They feel like part of our team.", name: "Facilities Manager", role: "Melbourne CBD commercial property", initials: "FM" },
  { quote: "We needed event security at short notice and they had a licensed crowd-control team sorted within a day. Smooth night, zero fuss.", name: "Events Coordinator", role: "Southbank venue", initials: "EC" },
  { quote: "Their mobile patrol caught a break-in attempt on our build site overnight and called it in straight away. Worth every cent.", name: "Site Manager", role: "Construction, western suburbs", initials: "SM" },
  { quote: "Reliable, professional and easy to deal with. The reporting after each shift means I always know what happened.", name: "Retail Operations", role: "Shopping centre, eastern suburbs", initials: "RO" },
  { quote: "Concierge guards who actually represent our brand at reception. Visitors get a warm welcome and we stay secure.", name: "Building Manager", role: "Corporate tower, Docklands", initials: "BM" },
  { quote: "Fast quote, fair price, licensed guards. Exactly what you want from a Melbourne security company.", name: "Warehouse Owner", role: "Logistics, northern suburbs", initials: "WO" },
];

const sectors = site.sectors;
const blogPosts = posts.slice(0, 3);

const faqs = [
  { q: "Are your security guards licensed in Victoria?", a: "Yes. Every guard holds a current Victorian security licence and is police-checked. We also hold a Private Security Business Licence you can verify with the Victoria Police Licensing and Regulation Division at any time." },
  { q: "What licence does a security company need in Victoria?", a: "In Victoria, a security business needs a Private Security Business Licence from Victoria Police, and every guard needs an individual security licence. Always ask for the licence number and check it before you book." },
  { q: "How quickly can you get a security guard on site?", a: "We can usually get a licensed guard on site within hours, not days, because we run a 24/7 dispatch team across Melbourne. For urgent jobs we'll confirm a deployment window the moment you call." },
  { q: "How much does it cost to hire a security guard in Melbourne?", a: "Cost depends on guard type, shift length and timing. We publish clear hourly ranges so you can budget before you call, then give you an itemised quote with no surprises." },
  { q: "Can I hire a security guard for one day or a short-term event?", a: "Yes. We cover one-off events, short-term cover and ongoing contracts. Tell us the dates and the site, and we'll work out the right number of guards for the job." },
  { q: "Do you provide security for the Christmas and event season?", a: "Yes. Spring and summer events, retail peaks and end-of-year functions are our busiest time. Book early, because licensed crowd controllers fill up fast across Melbourne in November and December." },
  { q: "Are your guards insured and police-checked?", a: "Yes. We carry public liability insurance and every officer passes a national police check before they work a single shift, so your business and your visitors are properly protected." },
  { q: "Can I request male or female security guards?", a: "Yes. Tell us what your site or event needs and we'll roster the right team, including female guards for bag checks, change rooms or events where that matters." },
];

const tags = ["Most requested", "", "Seasonal", "Highest value"];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": ["Organization", "SecurityService", "LocalBusiness"], "@id": site.url + "/#org",
      name: site.brand, url: site.url, telephone: site.phone, areaServed: "Melbourne, Victoria, Australia",
      address: { "@type": "PostalAddress", addressLocality: "Melbourne", addressRegion: "VIC", addressCountry: "AU" },
      description: "Licensed Melbourne security company providing security guards, mobile patrols, event and commercial security across Greater Melbourne." },
    { "@type": "WebSite", "@id": site.url + "/#website", url: site.url, name: site.brand, publisher: { "@id": site.url + "/#org" } },
    { "@type": "FAQPage", mainEntity: faqs.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
  ],
};
---
<Base>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header />

  <!-- HERO with quote form -->
  <section class="hero">
    <div class="wm wm-hero" aria-hidden="true" set:html={animMark('#F5F1E8', '#C7D43F', '#C7D43F')} />
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow" style="color:var(--lime-soft)">Licensed security company in Melbourne</span>
        <h1 style="margin-top:14px">Melbourne security company<br/>that protects<br/>what <em class="u-underline">matters</em></h1>
        <p class="lead">Forget unreliable guards and locked-up worries. SCM gives you licensed, insured, police-checked security that's on call 24/7. Your people, property and events, properly protected.</p>
        <div class="hero-chips">
          <span class="chip"><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span> 5.0 rating</span>
          <span class="chip"><span class="ldot"></span> 24/7 monitoring</span>
          <span class="chip">Victorian licensed</span>
        </div>
      </div>

      <div class="hero-form reveal">
        <form id="quoteForm" novalidate>
          <h2 class="hf-title">Get a free security quote</h2>
          <p class="hf-sub">Fast response, no obligation, available 24/7.</p>
          <div class="hf-row">
            <div class="hf-field"><label for="qName">Your name</label><input id="qName" name="name" type="text" required placeholder="Full name" /></div>
            <div class="hf-field"><label for="qPhone">Phone</label><input id="qPhone" name="phone" type="tel" required placeholder="04xx xxx xxx" /></div>
          </div>
          <div class="hf-field"><label for="qService">What do you need?</label>
            <select id="qService" name="service" required>
              <option value="">Choose a service</option>
              <option value="guards">Security guards</option>
              <option value="patrol">Mobile patrols</option>
              <option value="event">Event security</option>
              <option value="construction">Construction site security</option>
              <option value="commercial">Commercial / concierge</option>
              <option value="other">Something else</option>
            </select>
          </div>
          <!-- conditional fields -->
          <div class="hf-cond" data-when="event">
            <div class="hf-row">
              <div class="hf-field"><label for="qEventType">Event type</label>
                <select id="qEventType" name="event_type"><option value="">Select</option><option>Private party</option><option>Festival / concert</option><option>Corporate event</option><option>Wedding</option><option>Other</option></select></div>
              <div class="hf-field"><label for="qGuests">Expected guests</label><input id="qGuests" name="guests" type="number" min="1" placeholder="e.g. 150" /></div>
            </div>
            <div class="hf-field"><label for="qDate">Event date</label><input id="qDate" name="event_date" type="date" /></div>
          </div>
          <div class="hf-cond" data-when="construction">
            <div class="hf-row">
              <div class="hf-field"><label for="qSuburb">Site suburb</label><input id="qSuburb" name="suburb" type="text" placeholder="e.g. Footscray" /></div>
              <div class="hf-field"><label for="qCover">Cover needed</label><select id="qCover" name="cover"><option value="">Select</option><option>Overnight</option><option>24/7</option><option>Weekends</option></select></div>
            </div>
          </div>
          <div class="hf-cond" data-when="patrol">
            <div class="hf-row">
              <div class="hf-field"><label for="qProp">Property type</label><select id="qProp" name="property"><option value="">Select</option><option>Commercial</option><option>Residential / strata</option><option>Industrial</option></select></div>
              <div class="hf-field"><label for="qFreq">Visits</label><select id="qFreq" name="frequency"><option value="">Select</option><option>Nightly</option><option>Weekly</option><option>On-call / alarm response</option></select></div>
            </div>
          </div>
          <div class="hf-cond" data-when="guards">
            <div class="hf-row">
              <div class="hf-field"><label for="qNum">How many guards?</label><input id="qNum" name="guards_count" type="number" min="1" placeholder="e.g. 2" /></div>
              <div class="hf-field"><label for="qWhen">When?</label><select id="qWhen" name="when"><option value="">Select</option><option>Right now (urgent)</option><option>This week</option><option>Ongoing contract</option></select></div>
            </div>
          </div>
          <div class="hf-cond" data-when="commercial">
            <div class="hf-field"><label for="qBiz">Business type</label><select id="qBiz" name="business"><option value="">Select</option><option>Office</option><option>Retail</option><option>Warehouse</option><option>Healthcare</option><option>Other</option></select></div>
          </div>
          <div class="hf-cond" data-when="other">
            <div class="hf-field"><label for="qMsg">Tell us briefly</label><textarea id="qMsg" name="message" rows="2" placeholder="What do you need help with?"></textarea></div>
          </div>
          <button type="submit" class="btn btn-primary">Get my free quote</button>
          <p class="hf-note">Prefer to talk? Call <a href={site.phoneHref} style="color:var(--olive);font-weight:600">{site.phone}</a>, 24/7.</p>
        </form>
        <div class="hf-success" id="qSuccess">
          <div class="tick" set:html={icons.shieldcheck} />
          <h3>Thanks, request received</h3>
          <p style="color:var(--muted);margin:0">A licensed SCM team member will call you back fast. For urgent cover, call {site.phone}.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE (directly after hero, seamless) -->
  <div class="marquee" aria-label="Industries we protect">
    <div class="marquee-track" id="mqTrack">
      {industries.map(i => <span>{i}</span>)}
      {industries.map(i => <span aria-hidden="true">{i}</span>)}
    </div>
  </div>

  <!-- ACCREDITATIONS / TRUSTED -->
  <section class="section bg-cream" style="padding:54px 0">
    <div class="container">
      <p class="acc-head">Trusted, licensed and accredited to protect Melbourne</p>
      <div class="acc-grid">
        {accreditations.map(a => (
          <div class="acc-badge reveal">
            <span class="ab-mark" set:html={icons[a.icon]} />
            <span><b>{a.name}</b><span>{a.sub}</span></span>
          </div>
        ))}
      </div>
      <p class="acc-note">Accreditations shown are confirmed on request. [CLIENT INPUT: add real client logos with permission.]</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-white" style="padding-bottom:0">
    <div class="container reveal" style="max-width:780px;text-align:center;margin:0 auto">
      <span class="eyebrow">Licensed security, done properly</span>
      <p style="font-family:var(--serif);font-size:clamp(1.35rem,2.6vw,1.85rem);line-height:1.38;color:var(--ink);margin:14px 0 0">SCM is a licensed Melbourne security company. We protect local businesses, building sites, events and homes with professional, police-checked guards, right across Greater Melbourne.</p>
      <p style="color:var(--muted);margin-top:16px">The phone gets answered around the clock, and every shift is backed by a current Victorian security licence and full insurance. Need one guard for a single night, or an ongoing patrol contract? Either way, you deal with a local team that turns up on time, looks the part, and does the job properly.</p>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section bg-white">
    <div class="container">
      {features.map(f => (
        <div class={"feature reveal" + (f.rev ? " rev" : "")}>
          <div class="feature-text">
            <h2>{f.title}</h2>
            <p>{f.body}</p>
            <ul class="proof">{f.proof.map(p => <li>{p}</li>)}</ul>
            <a class="link" href={f.link.href}>{f.link.label} &rarr;</a>
          </div>
          <div class="feature-media">
            <span class="scan" aria-hidden="true"></span>
            <img src={f.img} width="560" height="420" alt={f.alt} loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- STATS -->
  <section class="section bg-soft" style="padding-top:0">
    <div class="container" style="padding-top:56px">
      <div class="stats">
        {site.stats.map(s => (<div class="stat reveal"><b>{s.n}</b><span>{s.label}</span></div>))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section bg-mist" id="services">
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow">What we do</span>
        <h2>Security services built <em>around your site</em></h2>
        <p style="color:var(--muted);margin-top:10px">From a single guard to a full event team, every service uses licensed, insured, police-checked people.</p>
      </div>
      <div class="cards">
        {site.services.map((s, i) => (
          <div class="card reveal">
            {tags[i] && <span class="tag">{tags[i]}</span>}
            <div class="ic" set:html={icons[s.icon]} />
            <h3>{s.name}</h3>
            <p>{s.blurb}</p>
            <a class="link" href={s.href}>Learn more &rarr;</a>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:34px">
        <a class="btn btn-dark" href={site.mega.services.hubHref}>View all security services &rarr;</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS CAROUSEL -->
  <section class="section bg-cream">
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow">What Melbourne clients say</span>
        <h2>Trusted by businesses, sites <em>and event teams</em></h2>
      </div>
      <div class="tcarousel">
        <div class="tviewport" id="tViewport">
          <div class="ttrack">
            {testimonials.map(t => (
              <figure class="tcard">
                <div class="stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                <blockquote>"{t.quote}"</blockquote>
                <figcaption>
                  <span class="avatar" aria-hidden="true">{t.initials}</span>
                  <span><b>{t.name}</b><span class="role">{t.role}</span></span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
        <div class="tctrl">
          <button class="tbtn" id="tPrev" aria-label="Previous reviews"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6"/></svg></button>
          <button class="tbtn" id="tNext" aria-label="Next reviews"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></button>
        </div>
      </div>
      <p class="trated reveal"><b>Rated 5.0</b> from local reviews &middot; [CLIENT INPUT: connect your Google reviews]</p>
    </div>
  </section>

  <!-- SECTORS -->
  <section class="section bg-sand" id="sectors">
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow">Sectors &amp; areas we serve</span>
        <h2>Security tailored to <em>every kind of site</em></h2>
        <p style="color:var(--muted);margin-top:12px">We work right across Greater Melbourne, from the CBD, Southbank and Docklands out through the suburbs, plus Geelong and Dandenong. Wherever your site sits, you get a local crew that knows the area and can be there quickly.</p>
      </div>
      <div class="sectors">
        {sectors.map(s => (
          <a class="sector reveal" href={s.href}>
            <img src={s.img} alt={s.alt} loading="lazy" />
            <span class="label">{s.name} &nearr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFFERENCE -->
  <section class="section bg-white">
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow">The SCM difference</span>
        <h2>Built on trust, response <em>and real accountability</em></h2>
        <p style="color:var(--muted);margin-top:12px">Plenty of companies can send a guard. Far fewer can prove they're licensed, turn up when they said they would, and tell you exactly what happened on site. That's the gap we close, every single shift.</p>
      </div>
      <div class="diff">
        <div class="col reveal"><div class="dic" set:html={icons.shieldcheck} /><h3>Licensed &amp; insured</h3><p>A current Victorian Private Security Business Licence, public liability cover and police-checked guards on every shift. Verify us with Victoria Police any time.</p></div>
        <div class="col feat reveal"><div class="dic" set:html={icons.bolt} /><h3>Rapid local response</h3><p>A 24/7 Melbourne dispatch team and GPS-verified patrols mean we deploy fast and prove it with real-time reporting, not vague promises.</p></div>
        <div class="col reveal"><div class="dic" set:html={icons.tag} /><h3>Transparent pricing</h3><p>Clear hourly ranges up front and itemised quotes with no hidden loadings, so you know exactly what you're paying and why.</p></div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section bg-olive" style="margin:0 24px">
    <div class="wm wm-how" aria-hidden="true" set:html={animMark('#C7D43F', '#2D2D1C', '#C7D43F')} />
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow" style="color:var(--lime-soft)">How it works</span>
        <h2 style="color:var(--cream)">Protection in <em style="color:var(--lime)">four simple steps</em></h2>
      </div>
      <div class="diff" style="grid-template-columns:repeat(4,1fr)">
        {steps.map(s => (
          <div class="col reveal" style="background:var(--olive-deep);border-color:rgba(255,255,255,.1)">
            <b style="font-family:var(--serif);font-size:1.8rem;color:var(--lime)">{s.n}</b>
            <h3 style="color:var(--cream);margin:8px 0 8px">{s.t}</h3>
            <p style="color:#CFCDBC">{s.d}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:30px">
        <a class="btn btn-primary" href="/our-process/">See our full process &rarr;</a>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="section bg-soft" id="blog">
    <div class="container">
      <div class="center-head reveal" style="max-width:46ch">
        <span class="eyebrow">Insights &amp; security tips</span>
        <h2>Practical advice from <em>Melbourne security pros</em></h2>
      </div>
      <div class="bgrid">
        {blogPosts.map(p => (
          <article class="bcard reveal">
            <a href={"/blog/" + p.slug + "/"} class="bimg"><img src={p.image} alt={p.imageAlt} loading="lazy" width="400" height="267" /></a>
            <div class="bbody">
              <span class="bcat">{p.category}</span>
              <h3><a href={"/blog/" + p.slug + "/"}>{p.title}</a></h3>
              <p>{p.excerpt}</p>
              <div class="bmeta"><span>{p.dateLabel}</span><span>{p.readMins} min read</span></div>
            </div>
          </article>
        ))}
      </div>
      <div style="text-align:center;margin-top:34px">
        <a class="btn btn-dark" href="/blog/">Read the blog &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container">
      <div class="center-head reveal">
        <span class="eyebrow">Good to know</span>
        <h2>Security company Melbourne <em>FAQ</em></h2>
      </div>
      <div class="faq">
        {faqs.map(f => (<details><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
      </div>
    </div>
  </section>

  <Footer />

  <script is:inline>
    // Hero quote form: conditional fields + submit
    (function(){
      const form = document.getElementById('quoteForm');
      if(!form) return;
      const svc = document.getElementById('qService');
      const conds = Array.from(document.querySelectorAll('.hf-cond'));
      svc.addEventListener('change', () => {
        conds.forEach(c => c.classList.toggle('show', c.dataset.when === svc.value));
      });
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if(!form.checkValidity()){ form.reportValidity(); return; }
        // TODO: POST to lead handler (Resend / Formspree) before launch (CLIENT INPUT).
        form.style.display='none';
        document.getElementById('qSuccess').classList.add('show');
      });
    })();
    // Testimonials carousel (scroll-snap)
    (function(){
      const vp = document.getElementById('tViewport');
      if(!vp) return;
      const step = () => { const card = vp.querySelector('.tcard'); return card ? card.offsetWidth + 22 : 320; };
      document.getElementById('tNext').addEventListener('click', () => {
        if(vp.scrollLeft + vp.clientWidth >= vp.scrollWidth - 5) vp.scrollTo({left:0,behavior:'smooth'});
        else vp.scrollBy({left:step(),behavior:'smooth'});
      });
      document.getElementById('tPrev').addEventListener('click', () => vp.scrollBy({left:-step(),behavior:'smooth'}));
      let timer = setInterval(() => { document.getElementById('tNext').click(); }, 5000);
      vp.addEventListener('mouseenter', () => clearInterval(timer));
    })();
  </script>
</Base>
